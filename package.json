{
  "name": "soccer-flow",
  "version": "0.1.0",
  "description": "Live soccer match tracking app",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"*.{ts,tsx,json}\" \"{docs,journal,config}/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"*.{ts,tsx,json}\" \"{docs,journal,config}/**/*.md\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run format && npm run lint:fix && npm run typecheck"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.2.5",
    "expo": "^56.0.0",
    "nativewind": "^4.2.4",
    "react": "^19.0.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-safe-area-context": "^5.0.0",
    "react-native-screens": "^4.25.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.0"
  },
  "private": true
}
